---
import Colaborador from "./forms/Colaborador.astro";
import Referido from "./forms/Referido.astro";

const {id} = Astro.props;
---
<section id={id} class="flex w-full relative justify-center bg-(--sorrento-gris) py-4 lg:py-8">
    <div class="flex flex-col w-full lg:w-7xl px-4 gap-y-2 lg:gap-y-4 z-1">
        <h2 class="w-full text-(--sorrento-azul) font-(--font-black) text-xl lg:text-4xl">Quiero más información</h2>
        <p class="text-sm font-(--font-medium) text-(--sorrento-negro)">Si estás pensando en construir tu hogar, invertir o conoces a alguien que esté interesado, ¡este es el momento!</p>
        <p class="text-sm font-(--font-medium) text-(--sorrento-negro)">Ingresa los datos requeridos y te mandamos toda la información sobre el proyecto de Sorrento</p>
        <div class="flex flex-col lg:flex-row overflow-hidden rounded-lg">
            <div class="flex w-full lg:w-3/5 overflow-hidden relative items-end z-1 h-80 lg:h-full">

                <img src="/img/form/img-form.webp" alt="" class="h-full w-auto object-cover absolute object-center hidden" id="img-1">
                <img src="/img/form/img-form-2.webp" alt="" class="h-full w-auto object-cover absolute object-center" id="img-2">
    
            </div>
            <div class="flex flex-col w-full lg:w-2/5 bg-(--sorrento-blanco) justify-center items-center px-4 lg:px-16 py-4 gap-4 h-fit lg:h-180">

                <nav class="flex gap-4 p-2 bg-(--sorrento-gris) rounded-full shadow-md">

                    <button class="btn-form active-form" id="col">Soy colaborador</button>
                    <button class="btn-form" id="ref">Quiero referir</button>

                </nav>

                <Colaborador class='' id="cont-col"/>
                <Referido class="hidden" id="cont-ref"/>
                
            </div>

            
        </div>
        
    </div>    
    <img src="/svg/sorrento-content-5.svg" alt="Contenido gráfico del logo de sorrento" class="absolute left-0 top-50 z-0 hidden lg:block">
    <img src="/svg/sorrento-content-6.svg" alt="Contenido gráfico del logo de sorrento" class="absolute right-8 bottom-12 z-0 hidden lg:block">

</section>
<script src="/src/scripts/form.js" />