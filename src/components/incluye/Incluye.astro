---
const {iconPath, text, className} = Astro.props;
---

<div class=`flex flex-col w-full bg-(--sorrento-gris) py-2 gap-1 justify-center items-center rounded-lg ${className}`>
    {iconPath && <img src={iconPath} />}
    <div class="flex justify-center items-center h-7">
        <p class="text-xs text-(--sorrento-negro) font-(--font-medium) text-center">{text}</p>
    </div>
</div>