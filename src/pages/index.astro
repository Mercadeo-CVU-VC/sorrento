---
import Layout from '../layouts/Layout.astro';
import Banner from '../components/Banner.astro';
import Form from '../components/Form.astro';
import Header from '../components/Header.astro';
import "../styles/global.css";
import Descripcion from '../components/Descripcion.astro';
import Apartamentos from '../components/Apartamentos.astro'
import Zc from '../components/Zc.astro';
import Footer from '../components/Footer.astro';

---

<Layout title="sorrento">
	<Banner ref="#content"/>
	<main class="flex flex-col gap-4 lg:gap-8 w-full items-center bg-(--sorrento-azul-oscuro-2)">
		<Header ref1="#description" ref2="#apt" ref3="#zonasComunes" ref4="#form" id='content'/>
		<Descripcion id="description" ref="#form"/>
		<!-- 
		<Apartamentos id="apt" ref="#form"/>
		<Zc id="zonasComunes"/>
		<Form id="form"/>
		-->
	</main>
	<Footer />
</Layout>
